datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  GALLERY_OWNER
  TENANT
}

enum ContractStatus {
  PENDING
  ACTIVE
  TERMINATED
  EXPIRED
}

enum InspectionType {
  DELIVERY
  RETURN
}

enum OdometerLogType {
  MONTH_START
  MONTH_END
  OIL_CHANGE
  FILTER_CHANGE
}

enum AlertType {
  OIL_CHANGE
  FILTER_CHANGE
}

enum AlertStatus {
  PENDING
  RESOLVED
}

model Gallery {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users           User[]
  cars            Car[]
  tenantProfiles  TenantProfile[]
  contracts       Contract[]
  odometerLogs    OdometerLog[]
  inspections     CarInspection[]
  alerts          MaintenanceAlert[]
  maintenanceRequests MaintenanceRequest[]

  @@map("galleries")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role
  galleryId    String?  @map("gallery_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  gallery       Gallery?       @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  tenantProfile TenantProfile?

  @@index([galleryId])
  @@map("users")
}

model Car {
  id                   String   @id @default(uuid()) @db.Uuid
  galleryId            String   @map("gallery_id") @db.Uuid
  plateNumber          String   @unique @map("plate_number") @db.VarChar(50)
  model                String   @db.VarChar(100)
  year                 Int
  color                String   @db.VarChar(50)
  licenseStartDate     DateTime @map("license_start_date") @db.Date
  licenseEndDate       DateTime @map("license_end_date") @db.Date
  currentOdometer      Int      @map("current_odometer")
  oilChangeInterval    Int      @map("oil_change_interval")
  filterChangeInterval Int      @map("filter_change_interval")
  imageUrl             String?  @map("image_url") @db.VarChar(2048) // Added car image URL
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  gallery      Gallery            @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  contracts    Contract[]
  odometerLogs OdometerLog[]
  alerts       MaintenanceAlert[]
  maintenanceRequests MaintenanceRequest[]

  @@index([galleryId])
  @@map("cars")
}

model TenantProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  galleryId         String   @map("gallery_id") @db.Uuid
  fullName          String   @map("full_name") @db.VarChar(255)
  nationalId        String   @default("") @map("national_id") @db.VarChar(50)
  nationalIdUrl     String   @map("national_id_url") @db.VarChar(2048)
  drivingLicenseUrl String   @map("driving_license_url") @db.VarChar(2048)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gallery   Gallery    @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  contracts Contract[]
  maintenanceRequests MaintenanceRequest[]

  @@index([galleryId])
  @@map("tenant_profiles")
}

model Contract {
  id               String         @id @default(uuid()) @db.Uuid
  galleryId        String         @map("gallery_id") @db.Uuid
  carId            String         @map("car_id") @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  rentalValue      Decimal        @map("rental_value") @db.Decimal(10, 2)
  startDate        DateTime       @map("start_date") @db.Date
  endDate          DateTime       @map("end_date") @db.Date
  allowedMonthlyKm Int            @map("allowed_monthly_km")
  status           ContractStatus @default(PENDING)
  documentUrl      String?        @map("document_url") @db.VarChar(2048) // Added contract document URL
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  // Relations
  gallery     Gallery         @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  car         Car             @relation(fields: [carId], references: [id], onDelete: Cascade)
  tenant      TenantProfile   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspections CarInspection[]
  odometerLogs OdometerLog[]

  @@index([galleryId])
  @@index([galleryId, carId])
  @@index([galleryId, tenantId])
  @@map("contracts")
}

model CarInspection {
  id              String         @id @default(uuid()) @db.Uuid
  galleryId       String         @map("gallery_id") @db.Uuid
  contractId      String         @map("contract_id") @db.Uuid
  type            InspectionType
  gasPercentage   Int            @map("gas_percentage")
  odometerReading Int            @map("odometer_reading")
  mediaUrls       String[]       @map("media_urls") @db.VarChar(2048)
  notes           String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")

  // Relations
  gallery  Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([galleryId, contractId])
  @@map("car_inspections")
}

model OdometerLog {
  id               String          @id @default(uuid()) @db.Uuid
  galleryId        String          @map("gallery_id") @db.Uuid
  contractId       String          @map("contract_id") @db.Uuid
  carId            String          @map("car_id") @db.Uuid
  type             OdometerLogType
  odometerValue    Int             @map("odometer_value")
  invoiceImageUrl  String?         @map("invoice_image_url") @db.VarChar(2048)
  createdAt        DateTime        @default(now()) @map("created_at")

  // Relations
  gallery  Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  car      Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([galleryId, carId])
  @@index([galleryId, contractId])
  @@map("odometer_logs")
}

model MaintenanceAlert {
  id        String      @id @default(uuid()) @db.Uuid
  galleryId String      @map("gallery_id") @db.Uuid
  carId     String      @map("car_id") @db.Uuid
  type      AlertType
  status    AlertStatus @default(PENDING)
  message   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  gallery Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  car     Car     @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([galleryId, carId])
  @@map("maintenance_alerts")
}

enum MaintenanceRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model MaintenanceRequest {
  id          String                   @id @default(uuid()) @db.Uuid
  galleryId   String                   @map("gallery_id") @db.Uuid
  carId       String                   @map("car_id") @db.Uuid
  tenantId    String                   @map("tenant_id") @db.Uuid
  issue       String                   @db.Text
  status      MaintenanceRequestStatus @default(PENDING)
  response    String?                  @db.Text
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  // Relations
  gallery   Gallery       @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  car       Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  tenant    TenantProfile @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@index([tenantId])
  @@map("maintenance_requests")
}
